        "jsCode": "const rawBody = $input.first().json.body;\nlet vehicle_no;\n\nif (typeof rawBody === \"string\") {\n  const parsed = JSON.parse(rawBody.replace(/\\n/g, '').trim());\n  vehicle_no = parsed.vehicle_no;\n} else {\n  vehicle_no = rawBody.vehicle_no;\n}\n\nreturn [{ json: { vehicle_no } }];"
