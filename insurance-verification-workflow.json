    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const policy = item.json;\n  const now = new Date();\n  const expiry = new Date(policy.expiry_date);\n  const isExpired = expiry < now;\n\n  return {\n    json: {\n      ...policy,\n      is_expired: isExpired ? \"yes\" : \"no\",\n      days_remaining: Math.floor((expiry - now) / (1000 * 60 * 60 * 24))\n    }\n  };\n});"
      },
